# ── Logging ──────────────────────────────────────────────────────────
# File path for structured log output (default: console only)
MINIMIND_LOG_FILE=

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
MINIMIND_LOG_LEVEL=INFO

# ── Data ─────────────────────────────────────────────────────────────
# Default directory for datasets
MINIMIND_DATA_DIR=./dataset

# ── Device ───────────────────────────────────────────────────────────
# Override auto-detected device (cuda:0, cpu, etc.)
# MINIMIND_DEVICE=cuda:0

# ── HuggingFace ──────────────────────────────────────────────────────
# Offline mode: set to "1" to disable HF downloads
# HF_HUB_OFFLINE=0

# Cache directory for HF models/datasets
# HF_HOME=~/.cache/huggingface

# ── Wandb ────────────────────────────────────────────────────────────
# WANDB_API_KEY=your_api_key_here
# WANDB_MODE=offline
